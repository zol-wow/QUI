<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
    <!-- Debug-instrumentation gate must load before every instrumented file -->
    <Script file="debug_gate.lua"/>
    <!-- Shared helpers must load first - provides common utilities for all modules -->
    <Script file="utils.lua"/>
    <Script file="border_registry.lua"/>
    <Script file="diagnostics_console.lua"/>
    <Script file="dumpspell.lua"/>
    <Script file="aura_events.lua"/>
    <Script file="registry.lua"/>
    <Script file="modules.lua"/>
    <Script file="media.lua"/>
    <Script file="gui_shell.lua"/>
    <Script file="compatibility.lua"/>
    <Script file="migrations.lua"/>
    <Script file="defaults.lua"/>
    <Script file="main.lua"/>
    <Script file="backdrop_deferred.lua"/>
    <!-- profile_io.lua (import/export engine) is options-only; loaded by QUI_Options/options.xml -->
    <Script file="font_system.lua"/>
    <Script file="scaling.lua"/>
    <Script file="uikit.lua"/>
    <!-- Settings framework: only these are needed on the login path — feature
         registration runs at login (module do-blocks call
         Registry:RegisterFeature(Schema.Feature{...}), and Schema.Feature ->
         CloneTable needs Util), and pins is touched by main.lua on profile change.
         The options-only framework files (providers/provider_panels/model_kit/
         fields/surfaces/surface_features/nav/sync/renderer) load on demand via
         QUI_Options/options.xml. -->
    <Script file="settings/util.lua"/>
    <Script file="settings_builders.lua"/>
    <Script file="settings/render_adapters.lua"/>
    <Script file="settings/registry.lua"/>
    <Script file="settings/schema.lua"/>
    <Script file="settings/provider_features.lua"/>
    <Script file="settings/pins.lua"/>
    <Script file="settings/pins_lifecycle.lua"/>
    <Script file="rangeutils.lua"/>
</Ui>

<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
    <!-- Buff/debuff icon template for SecureAuraHeaderTemplate children.
         The header creates one of these per visible aura and handles all
         protected operations (Show, Hide, SetPoint, SetSize) in its own
         secure execution context, avoiding ADDON_ACTION_BLOCKED taint. -->
    <Button name="QUIAuraIconTemplate" inherits="SecureActionButtonTemplate" virtual="true">
        <Size x="30" y="30"/>
        <Attributes>
            <Attribute name="type" value="cancelaura"/>
        </Attributes>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Icon" setAllPoints="true">
                    <TexCoords left="0.08" right="0.92" top="0.08" bottom="0.92"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture parentKey="BorderTop">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                    <Size y="2"/>
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
                <Texture parentKey="BorderBottom">
                    <Anchors>
                        <Anchor point="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                    <Size y="2"/>
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
                <Texture parentKey="BorderLeft">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                    <Size x="2"/>
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
                <Texture parentKey="BorderRight">
                    <Anchors>
                        <Anchor point="TOPRIGHT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                    <Size x="2"/>
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
                <FontString parentKey="Stacks" inherits="NumberFontNormal">
                    <Anchors>
                        <Anchor point="BOTTOMRIGHT" x="-1" y="1"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Cooldown parentKey="Cooldown" inherits="CooldownFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
            </Cooldown>
        </Frames>
    </Button>
    <Button name="QUIAuraTemplate" inherits="QUIAuraIconTemplate" framelevel="4" registerForClicks="RightButtonUp, RightButtonDown" virtual="true"/>
</Ui>

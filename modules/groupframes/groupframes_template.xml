<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
    <!-- SecureGroupHeader child template. OnLoad fires synchronously as each
         child is created by the secure header during CreateHeaders() at
         ADDON_LOADED, where the script execution-time budget is effectively
         unlimited — decorating 40+ raid frames on a runtime tick trips
         "script ran too long" inside NineSlice.lua:SetBackdrop. -->
    <Button name="QUIGroupUnitButtonTemplate" inherits="SecureUnitButtonTemplate,BackdropTemplate" virtual="true">
        <Scripts>
            <OnLoad>
                if QUI_GroupFrames and QUI_GroupFrames.InitializeHeaderChild then
                    QUI_GroupFrames:InitializeHeaderChild(self)
                end
            </OnLoad>
        </Scripts>
    </Button>
</Ui>
